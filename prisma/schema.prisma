// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PropertyType {
  APARTMENT
  BUNGALOW
  TOWNHOUSE
  MAISONETTE
  STUDIO
  SINGLE_ROOM
}

model RentEntry {
  id           String       @id @default(uuid())
  userId       String?
  estate       String
  apartment    String?
  rent         Int
  bedrooms     Int
  propertyType PropertyType
  furnished    Boolean
  comment      String?
  latitude     Float
  longitude    Float
  createdAt    DateTime     @default(now())
  user         User?        @relation(fields: [userId], references: [id])
}

model User {
  id      String      @id @default(uuid())
  email   String      @unique
  name    String?
  entries RentEntry[]
}
